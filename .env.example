# .env for the server-side docker compose stack.
# Copy to .env and fill in values for your setup.
# The Pi is configured separately — see cat_detect/main.py --help.

# ── Captures ──────────────────────────────────────────────────────────────────

# Path to the captures directory on this machine.
# Should point at the same share the Pi writes to (NFS, SMB, local disk, etc.).
CAPTURES_DIR=/mnt/share/CatCam

# ── Pi connection ─────────────────────────────────────────────────────────────
# These tell the server how to reach the Pi's HTTP stream server.
# Only needed if you run the Pi with the --stream flag.
# Leave blank to disable live feed and Pi metrics.

# MJPEG stream URL — shown as a live feed on in-progress event pages.
STREAM_URL=http://catcam.local:8085/

# Pi metrics URL — same host/port as STREAM_URL.
# When set, the metrics page shows Pi CPU/temp/memory in addition to server stats.
PI_METRICS_URL=http://catcam.local:8085/

# ── Auto-label GPU service ────────────────────────────────────────────────────
# URL of the auto-label sidecar (used by the API to reach the GPU service).
# The default works when running the full compose stack on the same machine.
# Override if you're running the sidecar separately or on a different host.
# AUTOLABEL_URL=http://localhost:8090

# ── Training ──────────────────────────────────────────────────────────────────
# Run with: docker compose --profile train run --rm training
# Outputs:
#   models/trained/catcam_yolov8n_best.pt          → copy to Pi, use with --model
#   models/trained/catcam_yolov8x-worldv2_best.pt  → set AUTOLABEL_MODEL to this path

# Base models to fine-tune (comma-separated). Defaults shown.
# TRAIN_BASE_MODELS=yolov8n.pt,yolov8x-worldv2.pt

# Number of training epochs (default: 100).
# TRAIN_EPOCHS=100

# Fraction of VRAM AutoBatch is allowed to use (default: 0.9 = 90%).
# TRAIN_VRAM_FRACTION=0.9

# ── Web UI ────────────────────────────────────────────────────────────────────

# Port the frontend is served on (default: 80).
# PORT=8080
