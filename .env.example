# Path to the captures directory on this machine.
# This should be the same directory the Pi writes to (e.g. an NFS/SMB mount).
CAPTURES_DIR=/mnt/share/CatCam

# MJPEG stream URL served by the Pi.
# Shown as a live feed on in-progress event pages.
# Leave blank if you're not using --stream on the Pi.
STREAM_URL=http://catcam.local:8085/

# Pi metrics URL — same host/port as STREAM_URL.
# When set, the metrics page shows Pi CPU/temp/memory instead of the capture box.
# Disk metrics always reflect the capture box regardless of this setting.
# Leave blank if you're not using --stream on the Pi.
PI_METRICS_URL=http://catcam.local:8085/

# Web UI port (default: 80)
# PORT=8080
